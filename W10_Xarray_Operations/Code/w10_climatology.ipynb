   "source": [
    "# calculate climatology using `.sel()` and `.groupby()` directly.\n",
    "precip_clim = (\n",
    "    ds.precip.sel(time=slice(\"1981-01-01\", \"2010-12-01\"))\n",
    "    .groupby(\"time.month\")\n",
    "    .mean(dim=\"time\")\n",
    ")\n",
    "precip_clim"
   ]
  },
